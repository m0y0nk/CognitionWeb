# ============================================
# CognitionWeb — Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ---
# Options: "gemini" (default, cheapest), "groq", "openai"
LLM_PROVIDER=gemini

# --- API Keys (set the one matching your provider) ---
GEMINI_API_KEY=your_gemini_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# --- Browser Settings ---
# Browser type: "chromium" (default), "firefox", "webkit"
BROWSER_TYPE=chromium
# Run in headless mode: "true" or "false" (default: false for demo)
HEADLESS=false

# --- Agent Settings ---
# Target URL to automate
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
# Maximum agent loop iterations before stopping
MAX_ITERATIONS=25
# Rate limit smart delay (in milliseconds) before sending a request. Set to 0 to disable.
RATE_LIMIT_DELAY_MS=1200

